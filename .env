SECRET_KEY=jwt_encrypt

DEBUG=True

DB_NAME=order_management

DB_USER=oms_user

DB_PASSWORD=your_password

DB_HOST=localhost

DB_PORT=3306



DJANGO_ENV=local
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=change-me-in-real-environments
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_LOG_LEVEL=INFO

MYSQL_DATABASE=order_management
MYSQL_USER=oms_user
MYSQL_PASSWORD=oms_password
MYSQL_ROOT_PASSWORD=oms_root_password
MYSQL_HOST=db
MYSQL_PORT=3306
DATABASE_URL=mysql://oms_user:oms_password@db:3306/order_management

REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=True
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=True
JWT_BLACKLIST_AFTER_ROTATION=True
JWT_UPDATE_LAST_LOGIN=False

DRF_PAGE_SIZE=20
API_VERSION=1.0.0

DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
DJANGO_SECURE_HSTS_SECONDS=0
