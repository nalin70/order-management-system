DJANGO_ENV=local
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=replace-with-a-32-plus-character-secret-key
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_LOG_LEVEL=INFO

DB_NAME=order_management
DB_USER=oms_user
DB_PASSWORD=oms_password
DB_HOST=127.0.0.1
DB_PORT=3306

MYSQL_DATABASE=order_management
MYSQL_USER=oms_user
MYSQL_PASSWORD=oms_password
MYSQL_ROOT_PASSWORD=oms_root_password

REDIS_URL=redis://127.0.0.1:6379/0
REDIS_CACHE_URL=redis://127.0.0.1:6379/1
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
USE_REDIS_CACHE=False

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=True
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=False
JWT_BLACKLIST_AFTER_ROTATION=False
JWT_UPDATE_LAST_LOGIN=False

DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
DJANGO_SECURE_HSTS_SECONDS=0
